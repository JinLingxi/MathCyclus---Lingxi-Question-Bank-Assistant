# API 密钥和环境变量 (绝对不能上传)
.env

# TikZ 绘图的临时图片和 PDF 缓存 (会占用大量空间，不需要上传)
.tikz_cache/
*.pdf


# Python 缓存文件
__pycache__/
*.py[cod]
*$py.class

# 操作系统生成的无用文件
.DS_Store
Thumbs.db
log.csv

# 自己加的东西
更新信息.txt
ocr_prompt.txt
AutoTikz.md
debug.log


# LaTeX 编译输出
main.synctex.gz
main.log
main.aux
main.out
main.toc
